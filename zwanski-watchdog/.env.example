# Zwanski Watchdog — environment template (copy to .env)

# PostgreSQL
DATABASE_URL=postgresql://watchdog:watchdog@localhost:5432/watchdog

# Redis
REDIS_URL=redis://localhost:6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# AI (classification)
OPENROUTER_API_KEY=

# Stripe (optional — billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# IPFS (Kubo HTTP API)
IPFS_API_URL=http://localhost:5001/api/v0

# MinIO (S3-compatible receipts)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET_RECEIPTS=receipts

# Auth
JWT_SECRET=change-me-use-long-random-string
JWT_REFRESH_SECRET=change-me-another-long-random-string

# Cloudflare (optional — API / proxy features)
CLOUDFLARE_API_TOKEN=

# Scanner
SCANNER_GITHUB_TOKEN=

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000

# Classifier
CLASSIFIER_CONCURRENCY=4
INTERNAL_WEBHOOK_URL=

# Disclosure / encryption
FINDING_ENCRYPTION_KEY=
