# ZWANSKI Bug Bounty Platform v3.0 - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# AI PROVIDER (Required)
# =============================================================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Alternative OpenRouter-compatible endpoints
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# =============================================================================
# GITHUB (Optional - for auto-sync and GitHub Actions recon)
# =============================================================================
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPO=https://github.com/your-org/your-repo.git

# =============================================================================
# TELEGRAM BOT (Optional - for OpenClaw Mobile C2)
# =============================================================================
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# WHATSAPP (Optional - for OpenClaw Mobile C2)
# =============================================================================
WHATSAPP_SESSION_PATH=/path/to/whatsapp-session.json

# =============================================================================
# DISCORD (Optional - for OpenClaw Mobile C2)
# =============================================================================
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=123456789012345678

# =============================================================================
# ZWANSKI WATCHDOG (optional — monorepo at ./zwanski-watchdog)
# =============================================================================
# Probed by /api/watchdog/status; override if you bind different ports.
WATCHDOG_API_URL=http://127.0.0.1:4000
WATCHDOG_WEB_URL=http://127.0.0.1:3000
WATCHDOG_CLASSIFIER_URL=http://127.0.0.1:8001

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=1337
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key

# =============================================================================
# MOBILE C2 (OpenClaw Integration)
# =============================================================================
OPENCLAW_ENABLED=true
OPENCLAW_AUTO_RECON=true
OPENCLAW_APPROVAL_REQUIRED=true
OPENCLAW_HEARTBEAT_INTERVAL_MINUTES=30

# =============================================================================
# SECURITY TOOL INTEGRATIONS
# =============================================================================
SUBDOMAINATOR_API_KEY=your_subdominator_key
NEUROSPLOIT_ENABLED=true
CRAWLAI_RAG_ENABLED=true
